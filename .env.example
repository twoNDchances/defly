# Root Docker Compose environment.
# Copy this file to `.env` in the repository root before running Docker Compose.

###############################################################################
# Docker Compose
###############################################################################

# Used by Docker Compose to prefix generated containers, networks, and volumes.
# Keep this stable after first `docker compose up`, otherwise Compose will create
# a separate set of named volumes.
COMPOSE_PROJECT_NAME=defly

# Image tags built/used by docker-compose.yml.
# MANAGER_IMAGE is shared by the `manager` and `worker` services.
# SERVER_DEFENDER_IMAGE must match orchestrator's deploy setting because
# orchestrator launches Defender containers from this local image.
MANAGER_IMAGE=defly-manager:latest
ORCHESTRATOR_IMAGE=defly-orchestrator:latest
SERVER_DEFENDER_IMAGE=defly-defender:latest

###############################################################################
# MariaDB
###############################################################################

# MariaDB service image version and credentials.
# DB_* values are reused by manager, worker, orchestrator, and deployed defenders.
MARIADB_VERSION=11.4
MARIADB_ROOT_PASSWORD=change_me_root
DB_DATABASE=defly_manager
DB_USERNAME=defly
DB_PASSWORD=change_me_app

###############################################################################
# Manager Application
###############################################################################

# Laravel app identity and runtime mode for the `manager` and `worker` services.
# APP_KEY should be set persistently in production. If left empty,
# manager/entrypoint.sh can generate one for the running container process.
APP_NAME="Defly Manager"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://localhost
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Host ports exposed by the `manager` web container.
# TLS_COMMON_NAME controls the self-signed Apache certificate CN/SAN generated
# inside manager when no certificate exists yet.
MANAGER_HTTP_PORT=80
MANAGER_HTTPS_PORT=443
MANAGER_TLS_COMMON_NAME=localhost

# Startup tasks executed by manager/entrypoint.sh for the web container.
# Worker overrides these to false because it should only process queue jobs.
MANAGER_RUN_MIGRATIONS=true
MANAGER_RUN_SEEDERS=true
MANAGER_RUN_OPTIMIZE=true
GENERATE_APP_KEY=true

# Laravel logging configuration for manager and worker.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Laravel state backends. This compose stack uses MariaDB-backed cache, session,
# and queue tables; no Redis/SQLite service is configured.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

###############################################################################
# Manager Mail / Resend
###############################################################################

# Mail settings for Laravel. With MAIL_MAILER=resend, set RESEND_API_KEY and use
# a MAIL_FROM_ADDRESS from a domain verified in Resend before sending real mail.
MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME="Defly Manager"
RESEND_API_KEY=
RESEND_DOMAIN=null
RESEND_PATH=resend

# Optional Resend webhook verification settings. Sending email does not require
# webhooks; set these only if you register /resend/webhook in Resend.
RESEND_WEBHOOK_SECRET=
RESEND_WEBHOOK_TOLERANCE=300

###############################################################################
# Manager Bootstrap User
###############################################################################

# Default manager user seeded by Laravel seeders.
USER_NAME=root
USER_EMAIL=root@defly.2ndproject.site
USER_PASSWORD=random

###############################################################################
# Manager API / UI
###############################################################################

# Manager API authentication, route prefixes, timezone, and Filament theme.
TOKEN_LOCATION=header
TOKEN_KEY_NAME=X-Token-Key
USER_AGENT=Defly/Manager
TIMEZONE=Asia/Ho_Chi_Minh
API_PREFIX=v1
GUI_PREFIX=defly-manager
THEME_COLOR=violet

###############################################################################
# Orchestrator
###############################################################################

# Orchestrator Django secret-key file path inside the orchestrator container.
# The file is stored in the orchestrator_secret named volume.
ORCHESTRATOR_SECRET_KEY_FILE=storage/secret/key.txt

# Django ALLOWED_HOSTS for requests received by orchestrator.
# Include `orchestrator` because manager/worker call https://orchestrator:8000.
ORCHESTRATOR_ALLOWED_HOSTS=127.0.0.1,localhost,manager,orchestrator

# Source service names allowed by orchestrator's manager-only middleware.
# `worker` is required because queued deployment jobs call orchestrator.
ORCHESTRATOR_ALLOWED_CLIENTS=manager,worker

# Orchestrator API route and method contract. Manager must use the same values.
ORCHESTRATOR_PATH_PREFIX=api/v1
ORCHESTRATOR_PATH_DEPLOYMENT=deployments
ORCHESTRATOR_PATH_ASSISTANT=assistant
ORCHESTRATOR_METHOD_ASSISTANT=get
ORCHESTRATOR_METHOD_DEPLOY=post
ORCHESTRATOR_METHOD_FOLLOW=get
ORCHESTRATOR_METHOD_CANCEL=delete

# Basic auth credentials used by manager/worker when calling orchestrator.
ORCHESTRATOR_USERNAME=defly-orchestrator
ORCHESTRATOR_PASSWORD=P@55w0rd

# TLS verification for manager/worker -> orchestrator calls.
# When false, manager verifies orchestrator using the certificate mounted from
# the orchestrator_tls named volume.
ORCHESTRATOR_TLS_SKIP_VERIFY=false

# Header name used to pass the requesting manager user email to orchestrator.
ORCHESTRATOR_EMAIL_HEADER_KEY=X-Executor

# OpenAI-compatible endpoint used by the Orchestrator assistant app.
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_TIMEOUT=60
AI_MAX_MESSAGES=40
AI_MAX_MESSAGE_CHARACTERS=4000
AI_API_KEY=

###############################################################################
# Defender Deployment
###############################################################################

# Compose volume key used by orchestrator when it launches Defender containers.
# Docker Compose creates the actual named volume as:
# ${COMPOSE_PROJECT_NAME}_${SERVER_DEFENDER_TLS_VOLUME}
# Manager mounts the same volume read-only to verify Defender certificates.
SERVER_DEFENDER_TLS_VOLUME=defender_tls

# TLS verification for manager/worker -> Defender calls after deployment.
# Keep false so manager verifies Defender certs from the shared TLS volume.
DEFENDER_SERVER_TLS_SKIP_VERIFY=false

###############################################################################
# Worker
###############################################################################

# Queue worker options for the `worker` service command.
# Increase worker replicas with: docker compose up -d --scale worker=3
WORKER_TRIES=3
WORKER_TIMEOUT=90
WORKER_MAX_TIME=3600

# Enable/Disable banner of Defly Defender when started
# Default: true     
export ABOUT_BANNER_ENABLE=

# Name used for generated Defender files such as TLS certificate/key
# Default: defender
export DEFENDER_NAME=

# Enable/Disable saving Defly Defender errors to file
# Default: false
export ERROR_FILE_ENABLE=

# Directory path where Defly Defender errors are stored
# Required when ERROR_FILE_ENABLE=true
# Default: storage/errors
export ERROR_DIRECTORY_PATH=

########################################################################################################################

# Enable/Disable HTTPS for Defly Defender Server
# Default: true
export SERVER_HTTPS_ENABLE=

# Enable/Disable write logs of Defly Defender Server to file
# Default: false
export SERVER_LOGGER_FILE_ENABLE=

# A path where logs of Defly Defender Server stored
# Default: storage/logs/server.log
export SERVER_LOGGER_FILE_PATH=

# Logging format for Defly Defender Server.
# References: https://docs.gofiber.io/middleware/logger/
# Syntax: use %tag% (example: %time%, %status%, %ip%)
# Default: '[%time%] {%from%}: %status% %ip% %method% %path% %bytesSent% %bytesReceived% %error%'
export SERVER_LOGGER_FORMAT=

# Timezone of Defly Defender Server displayed in logging
# Default: Asia/Ho_Chi_Minh
export SERVER_LOGGER_TIMEZONE=

# Port number for Defly Defender Server
# Default: 9947
export SERVER_PORT=

# Base path prefix for Defender Server routes
# Default: api/v1
export SERVER_CONTROLLER_PATH_PREFIX=

# Path segment for Defender Server state routes
# Default: state
export SERVER_CONTROLLER_PATH_STATE=

# HTTP method for checking state
# Default: get
export SERVER_CONTROLLER_METHOD_CHECK=

# HTTP method for inspecting state
# Default: post
export SERVER_CONTROLLER_METHOD_INSPECT=

# Path segment for Defender proxy gate routes
# Default: gate
export SERVER_CONTROLLER_PATH_GATE=

# HTTP method for locking Defender proxy gate
# Default: put
export SERVER_CONTROLLER_METHOD_LOCK=

# HTTP method for unlocking Defender proxy gate
# Default: delete
export SERVER_CONTROLLER_METHOD_UNLOCK=

# Path segment for Defender Server policy routes
# Default: policies
export SERVER_CONTROLLER_PATH_POLICIES=

# HTTP method for applying policies
# Default: put
export SERVER_CONTROLLER_METHOD_APPLY=

# HTTP method for revoking policies
# Default: delete
export SERVER_CONTROLLER_METHOD_REVOKE=

# Path segment for Defender Server decision routes
# Default: decisions
export SERVER_CONTROLLER_PATH_DECISIONS=

# HTTP method for implementing decisions
# Default: put
export SERVER_CONTROLLER_METHOD_IMPLEMENT=

# HTTP method for suspending decisions
# Default: delete
export SERVER_CONTROLLER_METHOD_SUSPEND=

# Storage backend used by Defender Server
# Default: file
# Available: file, memory
export SERVER_STORAGE_TYPE=

# Path to Defender Server storage file
# Required when SERVER_STORAGE_TYPE=file
# Default: storage/data/data.yaml
export SERVER_STORAGE_PATH=

# Manager IP address or host allowed to access Defender Server
# Default: manager
export SERVER_SECURITY_MANAGER=

# Username for Defender Server basic authentication
# Default: defly-defender
export SERVER_SECURITY_USERNAME=

# Password for Defender Server basic authentication
# Default: P@55w0rd
export SERVER_SECURITY_PASSWORD=

########################################################################################################################

# Backend URL
# Default: http://localhost
export PROXY_BACKEND_URL=

# Enable/Disable write logs of Defly Defender Proxy to file
# Default: false
export PROXY_LOGGER_FILE_ENABLE=

# A path where logs of Defly Defender Proxy stored
# Default: storage/logs/proxy.log
export PROXY_LOGGER_FILE_PATH=

# Logging format for Defly Defender Proxy.
# References: https://docs.gofiber.io/middleware/logger/
# Syntax: use %tag% (example: %time%, %status%, %ip%)
# Default: '[%time%] {%from%}: %status% %ip% %method% %path% %bytesSent% %bytesReceived% %error%'
export PROXY_LOGGER_FORMAT=

# Timezone of Defly Defender Proxy displayed in logging
# Default: Asia/Ho_Chi_Minh
export PROXY_LOGGER_TIMEZONE=

# Port number for Defly Defender Proxy
# Default: 9948
export PROXY_PORT=

# Enable/Disable trusted proxies
# Default: false
export PROXY_TRUSTED_ENABLE=

# Comma-separated list of trusted proxy IPs or CIDRs
# Required when PROXY_TRUSTED_ENABLE=true
# Example: 127.0.0.1,10.0.0.0/8,192.168.1.0/24
export PROXY_TRUSTED_LIST=

# Preserve original Host header when forwarding request to backend
# Default: true
export PROXY_PRESERVE_HOST=

# Assign a score to the severity level of the Alert
# Default: 6
export PROXY_SEVERITY_ALERT=

# Assign a score to the severity level of the Critical
# Default: 5
export PROXY_SEVERITY_CRITICAL=

# Assign a score to the severity level of the Emergency
# Default: 7
export PROXY_SEVERITY_EMERGENCY=

# Assign a score to the severity level of the Error
# Default: 4
export PROXY_SEVERITY_ERROR=

# Assign a score to the severity level of the Info
# Default: 1
export PROXY_SEVERITY_INFO=

# Assign a score to the severity level of the Notice
# Default: 2
export PROXY_SEVERITY_NOTICE=

# Assign a score to the severity level of the Warning
# Default: 3
export PROXY_SEVERITY_WARNING=

# Assign a level of investigation when a violation occurs
# Default: 1
export PROXY_VIOLATION_LEVEL=

# Assign a number of score to take action when a violation occurs
# Default: 5
export PROXY_VIOLATION_SCORE=
